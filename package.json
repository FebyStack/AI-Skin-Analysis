{
  "name": "ai-skin-analysis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json",
    "build:server": "esbuild server/api/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist-server/index.js --external:sharp --external:pg",
    "lint": "eslint .",
    "verify": "npm run typecheck && npm run typecheck:server && npm run test && npm run build"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "bcryptjs": "^2.4.3",
    "express": "^4.22.2",
    "onnxruntime-web": "^1.27.0",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.2",
    "eslint": "^9.12.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
